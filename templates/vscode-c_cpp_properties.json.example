{
    "configurations": [
        {
            "name": "PlatformIO",
            "includePath": [
                "${workspaceFolder}/firmware/include",
                "${workspaceFolder}/firmware/src",
                "${env:USERPROFILE}/.platformio/packages/framework-arduinoespressif32/**",
                "${workspaceFolder}/firmware/.pio/libdeps/esp32dev/**"
            ],
            "defines": [
                "ARDUINO_ESP32_DEV",
                "ARDUINO_ARCH_ESP32",
                "ESP32"
            ],
            "compilerPath": "${env:USERPROFILE}/.platformio/packages/toolchain-xtensa-esp32/bin/xtensa-esp32-elf-g++",
            "cStandard": "gnu11",
            "cppStandard": "gnu++11",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
}
